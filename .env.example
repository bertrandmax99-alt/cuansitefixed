# Copy this file to .env and fill in the values before running locally.
# These same variables must be added to your Vercel project settings.

# ── Neon PostgreSQL ───────────────────────────────────────────────
# Get this from: https://neon.tech → Your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Cloudinary (image uploads) ────────────────────────────────────
# Get these from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Session Security ──────────────────────────────────────────────
# Any long random string (used to sign cookies)
SESSION_SECRET=change-me-to-a-long-random-string
